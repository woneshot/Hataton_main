script = ExtResource("2_qse75")
condition_type = 2
condition_value = "defeated_vex"
lines = Array[String](["Ты сделал достаточно. Я признаю тебя", "Как только ты покинешь мои владения, мои чары вступят в силу", "Заклятие отступит частично. Это все, что я могу сделать"])
