[sub_resource type="Resource" id="Resource_deb0d"]
script = ExtResource("2_qse75")
lines = Array[String](["Я понимаю твою трагедию, странник", "Но как ты знаешь, в этом мире ничего не бывает просто так", "Если бы ты мог как-нибудь мне помочь...", "О, нет! На нас напали Вексы!"])
